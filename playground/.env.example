NEXT_PUBLIC_BASE_URL=https://yourapp.com

# ── Meta / WhatsApp ──────────────────────────────────────────────────────────
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
NEXT_PUBLIC_WA_CONFIG_ID=your_wa_config_id

# ── Facebook Login ───────────────────────────────────────────────────────────
NEXT_PUBLIC_META_CONFIG_ID=your_meta_config_id
NEXT_PUBLIC_FB_SCOPE=public_profile,email,pages_show_list

# ── Instagram (own OAuth) ────────────────────────────────────────────────────
NEXT_PUBLIC_IG_APP_ID=your_ig_app_id
IG_APP_SECRET=your_ig_app_secret
NEXT_PUBLIC_IG_SCOPE=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments,instagram_business_content_publish

# ── Instagram via Facebook Login for Business ────────────────────────────────
NEXT_PUBLIC_IG_FB_SCOPE=instagram_basic,instagram_content_publish,instagram_manage_comments,instagram_manage_insights,pages_show_list,pages_read_engagement,instagram_manage_messages

# ── Google ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
